{
  "plansDirectory": "docs/plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if echo \"$f\" | grep -qE '\\.(ts|tsx|js|jsx)$'; then bun run biome check \"$f\" || exit 2; fi; }",
            "timeout": 30,
            "statusMessage": "Running biome check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run test",
            "timeout": 120,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  }
}
